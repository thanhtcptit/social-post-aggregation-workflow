# Facebook credentials
FB_EMAIL=your_facebook_email@example.com
FB_PASSWORD=your_facebook_password

# OpenAI
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o-mini

# LLM provider: openai | anthropic | gemini
LLM_PROVIDER=openai

# Optional: alternative provider keys
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Storage paths (relative to project root)
COOKIE_PATH=data/browser_profiles
DB_PATH=data/cache.db

# Chrome profile folder name (see chrome://version → Profile Path, use folder name only)
CHROME_PROFILE=Profile 1

FB_COOKIES=[{"name":"c_user","value":"...","domain":".facebook.com","path":"/"},{"name":"xs","value":"...","domain":".facebook.com","path":"/"}]

VERBOSE=true