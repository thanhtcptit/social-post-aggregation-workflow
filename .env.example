# Facebook credentials
FB_EMAIL=your_facebook_email@example.com
FB_PASSWORD=your_facebook_password

# OpenAI
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o-mini

# LLM provider: openai | anthropic | gemini
